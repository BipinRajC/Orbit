# macOS
.DS_Store
**/.DS_Store

# ── Environment files — NEVER commit secrets ──────────────────────────────────
# Root
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging

# Backend
backend/.env
backend/.env.*
!backend/.env.example

# Frontend
frontend/.env
frontend/.env.*
!frontend/.env.local.example
# ──────────────────────────────────────────────────────────────────────────────

# Python
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/*.egg-info/

# Node / Next.js
frontend/node_modules/
frontend/.next/

# Supabase
supabase/.branches/
supabase/.temp/

# Editor
.idea/
.vscode/
*.swp
*.swo

# Worktrees
.worktrees/

# Misc
*.log
dist/
build/

# Context files (generated, not source)
docs/*CONTEXT*.md

# Extracted clips
backend/clips/
