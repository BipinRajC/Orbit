# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (transcription via Whisper + LLM via cascadeflow)
GROQ_API_KEY=gsk_...

# Anthropic (moment extraction + content generation)
ANTHROPIC_API_KEY=sk-ant-...

# Hindsight memory
HINDSIGHT_BASE_URL=https://your-hindsight-instance.com
HINDSIGHT_API_KEY=your-hindsight-key

# Optional overrides
HINDSIGHT_BANK_ID=contentos-demo
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]
CASCADE_DRAFTER_MODEL=llama-3.1-8b-instant
CASCADE_VERIFIER_MODEL=llama-3.3-70b-versatile
CLIP_STORAGE_PATH=/app/clips
DEFAULT_PLATFORMS=["instagram_reels","youtube_shorts","linkedin"]
